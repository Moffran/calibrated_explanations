{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calibrated-explanations.readthedocs.io/schemas/governance_event_schema_v1.json",
  "title": "GovernanceEventV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "event_id",
    "event_name",
    "decision",
    "identifier",
    "source",
    "trusted",
    "actor",
    "timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_name": {
      "type": "string",
      "const": "plugin.registration.decision"
    },
    "decision": {
      "type": "string",
      "enum": [
        "accepted_registration",
        "skipped_untrusted",
        "skipped_denied",
        "checksum_failure",
        "denied_registration"
      ]
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "trusted": {
      "type": "boolean"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "reason_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "invocation_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "request_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "plugin_identifier": {
      "type": [
        "string",
        "null"
      ]
    },
    "details": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
