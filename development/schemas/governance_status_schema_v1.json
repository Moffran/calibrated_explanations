{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance Status Artifact Schema v1.0",
  "description": "CI-derived governance status artifact for calibrated_explanations. This is a DERIVED CI ARTIFACT, not a runtime governance event schema. It must not be placed in src/calibrated_explanations/schemas/. Source: development/schemas/governance_status_schema_v1.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "run", "lint", "schema_checks"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version. Must be '1.0'."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp when this artifact was generated."
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "run_id", "commit"],
      "description": "CI run context. Fields are null when running outside CI.",
      "properties": {
        "workflow": {
          "type": ["string", "null"],
          "description": "GitHub Actions workflow name (GITHUB_WORKFLOW env var)."
        },
        "run_id": {
          "type": ["string", "null"],
          "description": "GitHub Actions run ID (GITHUB_RUN_ID env var)."
        },
        "commit": {
          "type": ["string", "null"],
          "description": "Git commit SHA (GITHUB_SHA env var)."
        }
      }
    },
    "lint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_checks_pr", "mypy", "ruff"],
      "description": "Lint gate results. Passed via CLI flags; 'unavailable' when not supplied.",
      "properties": {
        "local_checks_pr": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "Result of make local-checks-pr / python scripts/local_checks.py --skip-main."
        },
        "mypy": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "Result of mypy type-check step."
        },
        "ruff": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "Result of ruff lint step."
        }
      }
    },
    "schema_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance_event_schema",
        "config_manager_usage",
        "logging_domains",
        "no_local_paths"
      ],
      "description": "Aggregated quality check results from report files. 'unavailable' when report file is absent.",
      "properties": {
        "governance_event_schema": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "ADR-028 governance event schema check (reports/quality/governance_event_schema_report.json)."
        },
        "config_manager_usage": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "ADR-034 ConfigManager usage check (reports/config_manager_usage_report.json)."
        },
        "logging_domains": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "STD-005 logger domain check (reports/quality/logging_domain_report.json)."
        },
        "no_local_paths": {
          "type": "string",
          "enum": ["passed", "failed", "unavailable"],
          "description": "No-local-paths check (reports/quality/no_local_paths_report.json)."
        }
      }
    }
  }
}
